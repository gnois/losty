-- url friendly sign (compat shim)
var sigurl = require('losty.sigurl')

-- length (optional) - limit string length to be returned, and signature length check later
return \secret, length ->
	var pen = sigurl(secret, length)
	return {
		sign = \value ->
			return pen.sign_raw(value)

		, verify = \sig, value ->
			return pen.verify_raw(sig, value)
	}
