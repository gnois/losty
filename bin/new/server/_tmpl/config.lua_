-- env is edited by gen.lua (called from run.sh/run.bat dev|prod)

local specs = {
    dev = {
        ENV    = 'dev'
        , SECRET = '@@APP_NAME@@-dev-secret-change-me'
    }
    , prod = {
        ENV    = 'prod'
        -- Change before deploying. Do NOT commit real secrets.
        , SECRET = '@@APP_NAME@@-prod-secret-change-me!'
    }
}

return specs['{env}'] or specs.dev
